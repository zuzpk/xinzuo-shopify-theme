{% comment %} Feed navigation menu link items natively from liquid settings into JSON arrays {% endcomment %}
{% capture links_json %}
  [
    {% for link in linklists[section.settings.menu].links %}
      {
        "title": {{ link.title | json }},
        "url": {{ link.url | json }}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
{% endcapture %}

{% capture header_context %}
  {
    "section_type": "header",
    "logo_text": {{ section.settings.logo_text | json }},
    "cart_count": {{ cart.item_count | json }},
    "menu_links": {{ links_json | strip_newlines }}
  }
{% endcapture %}

<zuz-theme-root data-context='{{ header_context | escape }}'></zuz-theme-root>

{% schema %}
{
  "name": "React Custom Header",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text Branding",
      "default": "ZUZJS KNIVES"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Select Navigation Menu",
      "default": "main-menu"
    }
  ],
  "presets": [
    {
      "name": "React Custom Header"
    }
  ]
}
{% endschema %}